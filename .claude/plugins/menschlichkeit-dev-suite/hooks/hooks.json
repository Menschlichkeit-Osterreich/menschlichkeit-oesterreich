{
  "hooks": [
    {
      "event": "SessionStart",
      "matcher": "startup|resume",
      "hooks": [
        {
          "type": "command",
          "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.js\""
        }
      ]
    },
    {
      "event": "PreToolUse",
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use.js\""
        }
      ]
    },
    {
      "event": "PostToolUse",
      "matcher": "Bash|Edit|Write",
      "hooks": [
        {
          "type": "command",
          "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use-failure.js\""
        }
      ]
    }
  ]
}
