# n8n Environment Configuration
# Für Menschlichkeit Österreich Multi-Service Integration
# HTTPS-enabled für DSGVO Art. 32 Compliance
#
# WICHTIG: Diese Datei enthält KEINE echten Credentials.
# Echte Werte ausschließlich via GitHub Secrets oder SOPS/.env.vault setzen.
# Siehe docs/security/secrets-management.md für Vault-Workflow.
#
# SECURITY AUDIT 2026-03: Frühere Version dieser Datei enthielt Klartext-Passwörter.
# Alle betroffenen Credentials wurden zur Rotation markiert (P0-SECURITY-001).

# === n8n Core Settings ===
N8N_USER=CHANGE_ME_n8n_admin_user
N8N_PASSWORD=CHANGE_ME_use_strong_password_min_20_chars
N8N_ENCRYPTION_KEY=CHANGE_ME_existing_or_new_32_char_key_do_not_rotate_blindly
N8N_WEBHOOK_SECRET=CHANGE_ME_shared_hmac_secret

# === HTTPS Configuration ===
N8N_DOMAIN=n8n.menschlichkeit-oesterreich.at
N8N_HOST=n8n.menschlichkeit-oesterreich.at
N8N_PORT=5678

# Let's Encrypt ACME Email
ACME_EMAIL=devops@menschlichkeit-oesterreich.at

# === Database Settings ===
N8N_DB_PASSWORD=CHANGE_ME_use_strong_db_password

# === Redis Settings ===
REDIS_PASSWORD=CHANGE_ME_use_strong_redis_password

# === Integration Endpoints ===
# Alle FastAPI-Routen liegen unter /api.
MOE_API_URL=http://host.docker.internal:8001/api
API_BASE_URL=http://host.docker.internal:8001/api
MOE_API_TOKEN=CHANGE_ME_api_token
MOE_CRM_URL=http://host.docker.internal:8000
MOE_FRONTEND_URL=http://host.docker.internal:3000
MOE_GAMES_URL=http://host.docker.internal:3000

# === Plesk Integration ===
# HINWEIS: Plesk-Credentials gehören NICHT in diese Datei.
# SSH-Key-Auth verwenden (siehe docs/operations/plesk-setup.md).
PLESK_HOST=CHANGE_ME_server_ip_or_hostname
PLESK_USER=CHANGE_ME_plesk_username
PLESK_SSH_PORT=22

# === GitHub Integration ===
GITHUB_REPO=Menschlichkeit-Osterreich/menschlichkeit-oesterreich-development
GITHUB_OWNER=CHANGE_ME_github_owner

# === Notification Settings ===
SLACK_WEBHOOK_URL=CHANGE_ME_slack_webhook_url
QUEUE_ALERT_SLACK_WEBHOOK=
QUEUE_ALERT_MAX_AGE_SECONDS=600
QUEUE_ALERT_DLQ_SIZE=0
QUEUE_ALERT_EMAIL_TO=devops@menschlichkeit-oesterreich.at

# Email für Error Notifications & System Integration
SMTP_HOST=mail.menschlichkeit-oesterreich.at
SMTP_PORT=587

# System E-Mail Accounts (Werte via GitHub Secrets setzen)
SMTP_USER=automation@menschlichkeit-oesterreich.at
SMTP_PASS=CHANGE_ME_use_github_secret

# Additional E-Mail Integration
INFO_EMAIL=info@menschlichkeit-oesterreich.at
INFO_EMAIL_PASS=CHANGE_ME_use_github_secret

ADMIN_EMAIL=office@menschlichkeit-oesterreich.at
ADMIN_EMAIL_PASS=CHANGE_ME_use_github_secret

CIVIMAIL_EMAIL=civi@menschlichkeit-oesterreich.at
CIVIMAIL_EMAIL_PASS=CHANGE_ME_use_github_secret

BOUNCE_EMAIL=bounce@menschlichkeit-oesterreich.at
BOUNCE_EMAIL_PASS=CHANGE_ME_use_github_secret

LOGGING_EMAIL=logging@menschlichkeit-oesterreich.at
LOGGING_EMAIL_PASS=CHANGE_ME_use_github_secret

# === Quality Check Integration ===
CODACY_PROJECT_TOKEN=CHANGE_ME_use_github_secret

# === Timezone ===
TZ=Europe/Vienna
