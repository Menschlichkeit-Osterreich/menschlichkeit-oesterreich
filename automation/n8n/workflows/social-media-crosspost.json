    {
      "parameters": {
        "url": "https://api.linkedin.com/v2/ugcPosts",
        "authentication": "none",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Bearer {{ $env.LINKEDIN_ACCESS_TOKEN }}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "X-Restli-Protocol-Version", "value": "2.0.0" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ author: 'urn:li:organization:' + $env.LINKEDIN_ORG_ID, lifecycleState: 'PUBLISHED', specificContent: { 'com.linkedin.ugc.ShareContent': { shareCommentary: { text: $('Prepare Platform Content').first().json.linkedin.text }, shareMediaCategory: 'NONE' } }, visibility: { 'com.linkedin.ugc.MemberNetworkVisibility': 'PUBLIC' } }) }}",
        "options": {}
      },
      "id": "linkedin-post",
      "name": "LinkedIn: Post Update",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1120, 540]
    },
    {
      "parameters": {
        "functionCode": "const results = [];\nconst nodes = ['Instagram: Publish', 'Facebook: Post to Page', 'X: Post Tweet', 'LinkedIn: Post Update'];\nconst platforms = ['instagram', 'facebook', 'x_twitter', 'linkedin'];\n\nfor (let i = 0; i < platforms.length; i++) {\n  try {\n    const nodeData = $node[nodes[i]]?.json;\n    results.push({\n      platform: platforms[i],\n      status: nodeData ? 'published' : 'skipped',\n      id: nodeData?.id || nodeData?.data?.id || null\n    });\n  } catch(e) {\n    results.push({ platform: platforms[i], status: 'error', error: e.message });\n  }\n}\n\nreturn [{ json: { success: true, results, timestamp: new Date().toISOString() } }];"
      },
