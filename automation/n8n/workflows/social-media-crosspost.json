      "id": "webhook-trigger",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.type }}",
              "operation": "isNotEmpty"
            }
          ]
        }
      },
      "id": "validate-input",
      "name": "Validate Input",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [460, 300]
    },
    {
      "parameters": {
        "functionCode": "const data = $input.first().json;\nconst type = data.type || 'news';\nconst title = data.title || '';\nconst body = data.body || data.excerpt || '';\nconst url = data.url || 'https://menschlichkeit-oesterreich.at';\nconst imageUrl = data.image_url || '';\nconst tags = data.tags || [];\n\nconst defaultHashtags = ['MenschlichkeitÖsterreich', 'Österreich', 'Zivilgesellschaft'];\nconst hashtags = [...new Set([...tags, ...defaultHashtags])].slice(0, 8);\nconst hashtagStr = hashtags.map(h => '#' + h.replace(/[^a-zA-ZäöüÄÖÜß0-9]/g, '')).join(' ');\n\n// Platform-spezifische Texte\nconst instagramCaption = `${title}\\n\\n${body.slice(0, 1800)}\\n\\n🔗 Link in Bio\\n\\n${hashtagStr}`;\nconst facebookMessage = `${title}\\n\\n${body.slice(0, 2000)}\\n\\n${url}\\n\\n${hashtagStr}`;\nconst xTweet = `${title}\\n\\n${body.slice(0, 180)}…\\n\\n${url}\\n\\n${hashtags.slice(0,3).map(h => '#'+h).join(' ')}`;\nconst linkedinPost = `${title}\\n\\n${body.slice(0, 2800)}\\n\\n${url}\\n\\n${hashtagStr}`;\n\nreturn [{\n  json: {\n    type, title, body, url, imageUrl,\n    instagram: { caption: instagramCaption, imageUrl },\n    facebook: { message: facebookMessage, link: url },\n    x_twitter: { text: xTweet.slice(0, 280) },\n    linkedin: { text: linkedinPost },\n    platforms: data.platforms || ['instagram', 'facebook', 'x_twitter', 'linkedin'],\n    originalData: data\n  }\n}];"
      },
      "id": "prepare-content",
      "name": "Prepare Platform Content",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [680, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.platforms.includes('instagram') }}",
              "value2": "true"
            }
          ]
        }
      },
