# OpenClaw Umgebungsvariablen – Beispieldatei
# Kopieren nach ~/.openclaw/.env und Werte eintragen

OPENAI_API_KEY=sk-...
MO_API_URL=http://localhost:8000
MO_API_TOKEN=your-api-token-here
GITHUB_TOKEN=ghp_...
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
ADMIN_TELEGRAM_USER_ID_1=your-telegram-user-id
OPENCLAW_HOOK_TOKEN=generate-with-openssl-rand-hex-32
SMTP_HOST=mail.menschlichkeit-oesterreich.at
SMTP_PORT=587
SMTP_USER=office@menschlichkeit-oesterreich.at
SMTP_PASS=your-smtp-password
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_API_KEY=your-n8n-api-key
