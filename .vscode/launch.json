{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev: Frontend (Vite)",
      "type": "pwa-node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:frontend"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug: API (FastAPI)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--env-file", ".env", "--host", "0.0.0.0", "--port", "8001", "--reload"],
      "cwd": "${workspaceFolder}/apps/api",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/apps/api",
        "ENVIRONMENT": "development"
      },
      "envFile": "${workspaceFolder}/apps/api/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Dev: Games (Next.js)",
      "type": "pwa-node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:games"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Dev: CRM (Drupal)",
      "type": "node-terminal",
      "request": "launch",
      "command": "php -S localhost:8000 -t apps/crm/web",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Dev: Forum (phpBB)",
      "type": "pwa-node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:forum"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Dev: Website + API",
      "configurations": ["Dev: Frontend (Vite)", "Debug: API (FastAPI)"],
      "stopAll": true
    },
    {
      "name": "Dev: Public Stack",
      "configurations": ["Dev: Frontend (Vite)", "Debug: API (FastAPI)", "Dev: CRM (Drupal)", "Dev: Games (Next.js)"],
      "stopAll": true
    }
  ]
}
