# Bitwarden API Key Login
# Get from: https://vault.bitwarden.eu/#/settings/security/security-keys
BW_CLIENTID=user.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
BW_CLIENTSECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Master Password (for vault unlock)
BW_PASSWORD=

# Optional: override bw binary path (default: found via PATH)
# BW_CLI_PATH=bw

# Optional: server URL (default: from bw config)
# BW_SERVER_URL=https://vault.bitwarden.eu

# Optional: timeout for CLI commands in ms (default: 30000)
# BW_TIMEOUT_MS=30000

# Optional: project root for secret management tools
# PROJECT_ROOT=/path/to/menschlichkeit-oesterreich-development
