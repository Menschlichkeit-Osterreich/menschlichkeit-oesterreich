{
  "version": "2.0",
  "provider": "bitwarden-secrets-manager",
  "repository": "Menschlichkeit-Osterreich/menschlichkeit-oesterreich-development",
  "organization": "peschull",
  "bsm": {
    "api_url": "https://api.bitwarden.eu",
    "identity_url": "https://identity.bitwarden.eu"
  },
  "projects": {
    "development": "moe-development",
    "staging": "moe-staging",
    "production": "moe-production"
  },
  "service_accounts": {
    "sa-api-dev": { "project": "moe-development", "service": "api" },
    "sa-api-stg": { "project": "moe-staging", "service": "api" },
    "sa-api-prod": { "project": "moe-production", "service": "api" },
    "sa-openclaw-dev": { "project": "moe-development", "service": "openclaw" },
    "sa-openclaw-prod": { "project": "moe-production", "service": "openclaw" },
    "sa-n8n-dev": { "project": "moe-development", "service": "n8n" },
    "sa-n8n-prod": { "project": "moe-production", "service": "n8n" },
    "sa-cicd": { "project": ["moe-staging", "moe-production"], "service": "cicd" },
    "sa-infra-dev": { "project": "moe-development", "service": "infra" },
    "sa-infra-prod": { "project": "moe-production", "service": "infra" }
  },
  "secrets": [
    {
      "bsm_key": "api/DATABASE_URL",
      "env_var": "DATABASE_URL",
      "services": ["api"],
      "environments": ["development", "staging", "production"],
      "rotate_days": 180,
      "required": true,
      "sensitive": true
    },
    {
      "bsm_key": "api/JWT_SECRET_KEY",
      "env_var": "JWT_SECRET_KEY",
      "services": ["api"],
      "environments": ["development", "staging", "production"],
      "rotate_days": 90,
      "required": true,
      "sensitive": true
    },
    {
      "bsm_key": "api/MOE_API_TOKEN",
      "env_var": "MOE_API_TOKEN",
      "services": ["api", "n8n", "openclaw"],
      "environments": ["development", "staging", "production"],
      "rotate_days": 180,
      "required": true,
      "sensitive": true
    },
    {
      "bsm_key": "api/N8N_WEBHOOK_SECRET",
      "env_var": "N8N_WEBHOOK_SECRET",
      "services": ["api", "n8n"],
      "environments": ["development", "staging", "production"],
      "rotate_days": 180,
      "required": true,
      "sensitive": true
    },
    {
      "bsm_key": "api/CIVICRM_SITE_KEY",
      "env_var": "CIVICRM_SITE_KEY",
      "services": ["api", "crm"],
      "environments": ["development", "staging", "production"],
      "rotate_days": 180,
      "required": true,
      "sensitive": true
    },
    {
      "bsm_key": "api/CIVICRM_API_KEY",
      "env_var": "CIVICRM_API_KEY",
      "services": ["api", "crm"],
      "environments": ["development", "staging", "production"],
      "rotate_days": 180,
      "required": true,
      "sensitive": true
    },
    {
      "bsm_key": "api/MAIL_PASSWORD",
      "env_var": "MAIL_PASSWORD",
      "services": ["api"],
      "environments": ["development", "staging", "production"],
      "rotate_days": 180,
      "required": true,
      "sensitive": true
    },
    {
      "bsm_key": "api/STRIPE_SECRET_KEY",
