# ── Datenbankverbindung (lokal) ──────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/menschlichkeit

# ── JWT Secret (Testumgebung) ────────────────────────────────
JWT_SECRET_KEY=test-secret-key-fuer-lokale-entwicklung-min32chars!!

# ── Test-Login-Credentials ──────────────────────────────────
# Rolle: sysadmin (höchste Rechte)
TEST_SYSADMIN_EMAIL=test-sysadmin@menschlichkeit-oesterreich.at
TEST_SYSADMIN_PASSWORD=TestSysAdmin2025!

# Rolle: admin (Vereinsadmin / Vorstandsvorsitz)
TEST_ADMIN_EMAIL=test-admin@menschlichkeit-oesterreich.at
TEST_ADMIN_PASSWORD=TestAdmin2025!

# Rolle: moderator (Vorstand / Redaktion)
TEST_VORSTAND_EMAIL=test-vorstand@menschlichkeit-oesterreich.at
TEST_VORSTAND_PASSWORD=TestVorstand2025!

# Rolle: moderator (Inhalte moderieren)
TEST_MODERATOR_EMAIL=test-moderator@menschlichkeit-oesterreich.at
TEST_MODERATOR_PASSWORD=TestModerator2025!

# Rolle: member (Ordentliches Mitglied)
TEST_MITGLIED_EMAIL=test-mitglied@menschlichkeit-oesterreich.at
TEST_MITGLIED_PASSWORD=TestMitglied2025!

# Rolle: member / Fördermitglied
TEST_FOERDERMITGLIED_EMAIL=test-foerdermitglied@menschlichkeit-oesterreich.at
TEST_FOERDERMITGLIED_PASSWORD=TestFoerder2025!

# Rolle: member / Status Inactive (gesperrtes Konto testen)
TEST_INAKTIV_EMAIL=test-inaktiv@menschlichkeit-oesterreich.at
TEST_INAKTIV_PASSWORD=TestInaktiv2025!

# ── API-Endpunkte (lokal) ────────────────────────────────────
VITE_API_URL=http://localhost:8001
