# .env.production.template — Menschlichkeit Österreich
# Produktions-Umgebungsvorlage (NICHT für lokale Entwicklung — dafür .env.example verwenden)
#
# ANLEITUNG:
#   1. Diese Datei NIEMALS committen oder ins Repository eincheckeln.
#   2. Auf dem Produktionsserver kopieren:
#      cp .env.production.template .env
#   3. Alle CHANGE_ME Platzhalter mit echten Werten befüllen.
#   4. Alle Passwörter und API-Keys zusätzlich als GitHub Secrets anlegen.
#      Siehe DEPLOYMENT_CONFIG.md für die vollständige Secrets-Übersicht.
#
# SICHERHEITSREGELN:
#   - Keine Secrets in dieses File hardcoden und committen
#   - Nur auf dem Server direkt bearbeiten
#   - Dateiberechtigungen: chmod 600 .env

# ==============================================================================
# SERVER-INFORMATION (öffentlich, keine Secrets)
# ==============================================================================

APP_ENV=production
NODE_ENV=production
APP_URL=https://menschlichkeit-oesterreich.at
MAIN_DOMAIN=menschlichkeit-oesterreich.at

# Server-Stack (zur Dokumentation)
DB_SERVER_TYPE=MariaDB 10.6.22
DB_SERVER_OS=Ubuntu 22.04
WEBSERVER=nginx 1.28.0
PHP_VERSION=8.4.11

# ==============================================================================
# SSH / DEPLOYMENT
# GitHub Secrets: PLESK_HOST, PLESK_PORT, PLESK_USER, PLESK_SSH_PRIVATE_KEY
# ==============================================================================

PLESK_HOST=plesk7.digimagical.com
PLESK_PORT=22
PLESK_USER=CHANGE_ME
PLESK_BASE_PATH=/var/www/vhosts/menschlichkeit-oesterreich.at/httpdocs
DEPLOY_STRATEGY=rsync

# ==============================================================================
# DATENBANKEN — MariaDB (Produktion)
# Alle Passwörter als GitHub Environment Secrets (production) anlegen.
# GitHub Secrets: *_DB_PASSWORD
# ==============================================================================

# Hauptdatenbank
MAIN_DB_HOST=localhost
MAIN_DB_PORT=3306
MAIN_DB_NAME=mo_main
MAIN_DB_USER=svc_main
MAIN_DB_PASSWORD=CHANGE_ME

# Forum
FORUM_DB_HOST=localhost
FORUM_DB_PORT=3306
FORUM_DB_NAME=mo_forum
FORUM_DB_USER=svc_forum
FORUM_DB_PASSWORD=CHANGE_ME

# Newsletter
NEWSLETTER_DB_HOST=localhost
NEWSLETTER_DB_PORT=3306
NEWSLETTER_DB_NAME=mo_newsletter
NEWSLETTER_DB_USER=svc_newsletter
NEWSLETTER_DB_PASSWORD=CHANGE_ME

# Support
SUPPORT_DB_HOST=localhost
SUPPORT_DB_PORT=3306
SUPPORT_DB_NAME=mo_support
SUPPORT_DB_USER=svc_support
SUPPORT_DB_PASSWORD=CHANGE_ME

# Abstimmungen (Votes)
VOTES_DB_HOST=localhost
VOTES_DB_PORT=3306
VOTES_DB_NAME=mo_votes
VOTES_DB_USER=svc_votes
VOTES_DB_PASSWORD=CHANGE_ME

# ==============================================================================
# SMTP — Plesk Mail Server
# GitHub Secrets: SMTP_HOST, SMTP_USER, SMTP_PASSWORD
# ==============================================================================

SMTP_HOST=CHANGE_ME
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_ENCRYPTION=tls
MAIL_FROM_NAME=Menschlichkeit Österreich

# E-Mail-Accounts (CHANGE_ME durch echte Adressen ersetzen)
MAIL_OFFICE=office@menschlichkeit-oesterreich.at
MAIL_CIVIMAIL=civimail@menschlichkeit-oesterreich.at
MAIL_BOUNCE=bounce@menschlichkeit-oesterreich.at
MAIL_ADMIN=admin@menschlichkeit-oesterreich.at

# ==============================================================================
# CiviCRM
# GitHub Secrets: CIVICRM_SITE_KEY, CIVICRM_API_KEY, CIVICRM_DB_PASSWORD
# ==============================================================================

CIVICRM_DB_HOST=localhost
CIVICRM_DB_NAME=mo_civicrm
CIVICRM_DB_USER=svc_civicrm
CIVICRM_DB_PASSWORD=CHANGE_ME
CIVICRM_SITE_KEY=CHANGE_ME
CIVICRM_API_KEY=CHANGE_ME

# ==============================================================================
# API / FastAPI
# GitHub Secrets: JWT_SECRET
# ==============================================================================

API_URL=https://api.menschlichkeit-oesterreich.at
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ==============================================================================
# n8n AUTOMATISIERUNG
# GitHub Secrets: N8N_USER, N8N_PASSWORD, N8N_ENCRYPTION_KEY, N8N_WEBHOOK_URL
# ==============================================================================

N8N_HOST=localhost
N8N_PORT=5678
N8N_USER=CHANGE_ME
N8N_PASSWORD=CHANGE_ME
N8N_ENCRYPTION_KEY=CHANGE_ME
N8N_WEBHOOK_URL=CHANGE_ME

# ==============================================================================
# EXTERNE API-KEYS
# GitHub Secrets: CODACY_API_TOKEN, FIGMA_API_TOKEN, GH_TOKEN
# ==============================================================================

# CODACY_API_TOKEN=CHANGE_ME
# FIGMA_API_TOKEN=CHANGE_ME
# FIGMA_FILE_KEY=mTlUSy9BQk4326cvwNa8zQ
# GH_TOKEN=CHANGE_ME

# ==============================================================================
# FEATURE FLAGS (Production-Defaults)
# ==============================================================================

FEATURE_REGISTRATION=true
FEATURE_DONATIONS=true
FEATURE_GAMES=true
FEATURE_NEWSLETTER=true
FEATURE_ANALYTICS=false

# ==============================================================================
# SICHERHEIT & LOGGING
# ==============================================================================

# Kein Debug-Modus in Produktion!
DEBUG=false
LOG_LEVEL=warning

# DSGVO: PII-Sanitizer aktiv halten
PII_SANITIZER_ENABLED=true
