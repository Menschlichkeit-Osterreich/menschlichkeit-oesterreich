#!/usr/bin/env bash
# Pre-push hook: validate repo baseline before push.

set -euo pipefail

export CODACY_SARIF_PATH="quality-reports/codacy-analysis.sarif"

echo "[pre-push] Running governance check..."
npm run governance:check

echo "[pre-push] Running MCP check..."
npm run mcp:check

echo "[pre-push] Running API tests..."
npm run test:api

echo "[pre-push] Running Codacy analysis..."
LOG_FILE="${TMPDIR:-/tmp}/codacy-run.log"
if ! node ./scripts/ci/run-codacy.mjs >"$LOG_FILE" 2>&1; then
  echo "[pre-push] Codacy analysis failed. Log excerpt:"
  tail -n 200 "$LOG_FILE" || true
  exit 1
fi

COUNT=$(node -e "const fs=require('fs'); const reportPath=process.env.CODACY_SARIF_PATH || 'quality-reports/codacy-analysis.sarif'; try { const s=fs.readFileSync(reportPath,'utf8'); const j=JSON.parse(s); const c=(j.runs||[]).reduce((a,r)=>a+((r.results||[]).length||0),0); console.log(String(c)); } catch (e) { console.log('0'); }")

echo "[pre-push] Findings total: ${COUNT}"
if [ "${CODACY_FAIL_ON_FINDINGS:-true}" = "true" ] && [ "$COUNT" -gt 0 ]; then
  echo "[pre-push] Push blocked (findings > 0). Set CODACY_FAIL_ON_FINDINGS=false to bypass locally."
  exit 2
fi

echo "[pre-push] OK - no blocking findings."
