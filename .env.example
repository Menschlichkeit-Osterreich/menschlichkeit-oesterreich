# Root workspace environment template
# Shared/bootstrap variables only. Service runtime variables live in:
#   - apps/api/.env.example
#   - apps/website/.env.example
#   - automation/n8n/.env.example
#   - .env.test.example

# GitHub / signing
GH_TOKEN=CHANGE_ME_GH_TOKEN
GPG_KEY_ID=CHANGE_ME_GPG_KEY_ID

# Deployment / workspace bootstrap
PLESK_HOST=CHANGE_ME_plesk-user@example-host
PLESK_PORT=22
PLESK_BASE_PATH=/var/www/vhosts/menschlichkeit-oesterreich.at/httpdocs
PLESK_FRONTEND_PATH=httpdocs
PLESK_API_PATH=subdomains/api/httpdocs
PLESK_CRM_PATH=subdomains/crm/httpdocs
PLESK_CRM_NATIVE_PATH=subdomains/crm/httpdocs/native
PLESK_GAMES_PATH=subdomains/games/httpdocs
LOCAL_WEBROOT=.
SSH_AUTH_MODE=agent
SSH_KEY_NAME=plesk

# OpenClaw local runtime
OC_ENV=development
OC_NATS_URL=nats://localhost:4222
OC_REDIS_URL=redis://localhost:6380
OC_PG_DSN=postgresql://oc:oc_dev_only@localhost:55432/oc
OC_QDRANT_URL=http://localhost:6333
OC_TOOL_GATEWAY_URL=http://localhost:9101
OC_AGENT_RUNTIME_URL=http://localhost:9100
OC_OPENAI_API_KEY=CHANGE_ME_OC_OPENAI_API_KEY
OC_GITHUB_TOKEN=CHANGE_ME_OC_GITHUB_TOKEN
OC_DEFAULT_MODEL=gpt-4.1-mini
OC_FALLBACK_MODEL=gpt-4.1-nano
OC_MAX_TOOL_CALLS=20
OC_MAX_MINUTES=15
OC_MAX_COST_EUR=0.20
OC_WORKSPACE_ROOT=/workspace
OC_OLLAMA_URL=http://localhost:11434
OC_LOCAL_MODEL=llama3.2
GROQ_API_KEY=
N8N_WEBHOOK_SECRET=CHANGE_ME_N8N_WEBHOOK_SECRET
OC_PII_SCRUB_EVENTS=true
OTEL_ENDPOINT=
