{
  "mcpServers": {
    "file-server": {
      "command": "node",
      "args": ["mcp-servers/file-server/index.js"],
      "env": {
        "PROJECT_ROOT": "${workspaceFolder}"
      }
    },
    "quality-reporter": {
      "command": "node",
      "args": ["mcp-servers/quality-reporter/index.js"],
      "env": {
        "PROJECT_ROOT": "${workspaceFolder}",
        "REPORTS_DIR": "${workspaceFolder}/quality-reports"
      }
    },
    "build-pipeline": {
      "command": "node",
      "args": ["mcp-servers/build-pipeline/index.js"],
      "env": {
        "PROJECT_ROOT": "${workspaceFolder}"
      }
    },
    "n8n-webhook": {
      "command": "node",
      "args": ["mcp-servers/n8n-webhook/index.js"],
      "env": {
        "PROJECT_ROOT": "${workspaceFolder}",
        "N8N_BASE_URL": "http://localhost:5678"
      }
    },
    "bitwarden-cli": {
      "command": "node",
      "args": ["mcp-servers/bitwarden-cli/index.js"],
      "env": {
        "PROJECT_ROOT": "${workspaceFolder}",
        "BW_CLIENTID": "${BW_CLIENTID}",
        "BW_CLIENTSECRET": "${BW_CLIENTSECRET}",
        "BW_PASSWORD": "${BW_PASSWORD}"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@2.2.3"]
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem@2026.1.14", "."]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory@2026.1.26"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking@2025.12.18"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@0.0.73"]
    },
    "codacy-mcp-server": {
      "command": "npx",
      "args": ["-y", "@codacy/codacy-mcp@0.6.21"],
      "env": {
        "CODACY_ACCOUNT_TOKEN": "${CODACY_ACCOUNT_TOKEN}"
      }
    }
  }
}
