# [DEPRECATED] laravel-env-production.env
# ──────────────────────────────────────────────────────────────────────────────
# STATUS: DEPRECATED – nicht mehr für neue Deployments verwenden.
# ERSATZ: apps/api/.env.example (FastAPI-Stack mit DATABASE_URL, JWT_SECRET_KEY etc.)
# GRUND: Enthält ausschliesslich Laravel-spezifische Variablen (SESSION_DRIVER,
#        BROADCAST_DRIVER, QUEUE_CONNECTION, PUSHER_*, BCRYPT_ROUNDS, APP_KEY),
#        die fuer den aktuellen FastAPI/Python-Stack irrelevant sind.
# ARCHIV: Diese Datei bleibt als historische Referenz erhalten, wird aber nicht
#         mehr deployed. Secrets werden ausschliesslich via Bitwarden Secrets Manager
#         verwaltet (secrets.manifest.json).
# DEPRECATED SEIT: 2026-04-04
# ──────────────────────────────────────────────────────────────────────────────
#
# [ORIGINAL] API .env Template – api.menschlichkeit-oesterreich.at
# Deployed via: scripts/plesk-config-manager.ps1 → /subdomains/api/httpdocs/.env
#
# HINWEIS: Dateiname historisch bedingt ("laravel" aus früherer Stack-Entscheidung).
# Aktueller Stack: FastAPI (Python). Alle Variablen gelten für die FastAPI-Umgebung.
# Alle REPLACE_WITH_*-Werte müssen vor dem Deploy durch echte Werte ersetzt werden.
# Niemals echte Credentials in diese Template-Datei committen.
#
# PRIMARY SYSTEM - Produktions-Konfiguration für api.menschlichkeit-oesterreich.at

APP_NAME="Menschlichkeit Österreich API"
APP_ENV=production
APP_KEY=base64:GENERATE_NEW_APP_KEY_HERE
APP_DEBUG=false
APP_URL=https://api.menschlichkeit-oesterreich.at

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database Configuration - MariaDB 10.6.22 @ digimagical.com
# Dedicated laravel_user (NICHT mo_wp_user)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mo_laravel_api
DB_USERNAME=laravel_user
DB_PASSWORD=CHANGE_ME_LARAVEL_DB_PASSWORD
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Database Performance Settings
DB_SOCKET=
DB_SSL_MODE=disabled
DB_SSL_CERT=
DB_SSL_KEY=
DB_SSL_CA=

# Redis Cache (falls verfügbar auf Plesk)
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Redis Configuration (optional)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration (Plesk SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp.menschlichkeit-oesterreich.at
MAIL_PORT=587
MAIL_USERNAME=api@menschlichkeit-oesterreich.at
MAIL_PASSWORD=MAIL_PASSWORD_HERE
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="api@menschlichkeit-oesterreich.at"
MAIL_FROM_NAME="${APP_NAME}"

# AWS (falls S3 für File Storage verwendet wird)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Pusher (falls Real-time Features benötigt)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=eu

# API Rate Limiting
API_RATE_LIMIT=60
API_RATE_LIMIT_WINDOW=1

# Security Settings
BCRYPT_ROUNDS=12
HASH_VERIFY=true

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://menschlichkeit-oesterreich.at,https://www.menschlichkeit-oesterreich.at
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# Plesk-spezifische Konfiguration
SERVER_SOFTWARE=nginx/1.28.0
PHP_VERSION=8.4.11
DB_SERVER=MariaDB 10.6.22
HOSTING_PROVIDER=digimagical.com

# Performance & Caching
OPCACHE_ENABLE=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# Monitoring & Logging
LOG_QUERIES=false
LOG_SLOW_QUERIES=true
SLOW_QUERY_TIME=2000

# Backup & Maintenance
BACKUP_ENABLED=true
MAINTENANCE_MODE=false