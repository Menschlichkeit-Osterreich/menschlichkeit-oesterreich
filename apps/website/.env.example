# Menschlichkeit Österreich – Frontend Umgebungsvariablen
# Kopiere diese Datei als .env.local und befülle die Werte.

# ── API Konfiguration ──────────────────────────────────────────────────────────
# VITE_API_URL ist der kanonische FastAPI-Endpunkt inklusive /api.
# VITE_API_BASE_URL bleibt für ältere Admin-/Legacy-Komponenten ohne /api-Suffix bestehen.
VITE_API_URL=http://localhost:8001/api
VITE_API_BASE_URL=http://localhost:8001
VITE_API_TIMEOUT_MS=15000

# ── CiviCRM ────────────────────────────────────────────────────────────────────
# Nur für Admin-/CRM-nahe Oberflächen verwenden, nicht für öffentliche Website-Flows.
VITE_CIVICRM_BASE_URL=https://crm.menschlichkeit-oesterreich.at
VITE_CIVICRM_API_ENDPOINT=/api/v4

# ── Zahlungen ─────────────────────────────────────────────────────────────────
# Stripe Publishable Key (beginnt mit pk_test_ oder pk_live_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_PLACEHOLDER

# ── Host-Variante ─────────────────────────────────────────────────────────────
# Optionaler Override: "production" | "staging" | "development" (Default: auto-detect)
# VITE_HOST_VARIANT=development
