# Menschlichkeit Österreich – Frontend Umgebungsvariablen
# Kopiere diese Datei als .env.local und befülle die Werte.

# ── API Konfiguration ──────────────────────────────────────────────────────────
# Basis-URL der FastAPI (Port 8001 in dev, Port 8000 legacy CRM)
VITE_API_URL=http://localhost:8001/api
VITE_API_BASE_URL=http://localhost:8000
VITE_API_TIMEOUT_MS=15000

# ── CiviCRM ────────────────────────────────────────────────────────────────────
VITE_CIVICRM_BASE_URL=https://crm.menschlichkeit-oesterreich.at
VITE_CIVICRM_API_ENDPOINT=/api/v4

# ── Zahlungen ─────────────────────────────────────────────────────────────────
# Stripe Publishable Key (beginnt mit pk_test_ oder pk_live_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_PLACEHOLDER
# PayPal Client-ID (Sandbox oder Live)
VITE_PAYPAL_CLIENT_ID=PAYPAL_CLIENT_ID_PLACEHOLDER

# ── OpenClaw Windows-Bridge ───────────────────────────────────────────────────
VITE_OPENCLAW_BRIDGE_URL=http://127.0.0.1:18790
