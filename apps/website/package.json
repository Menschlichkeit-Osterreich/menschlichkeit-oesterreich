{
  "name": "@moe/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "seo:assets": "node scripts/generate-seo-assets.mjs",
    "docs:legal": "node scripts/sync-legal-docs.mjs",
    "prebuild": "npm run seo:assets && npm run docs:legal",
    "dev": "vite",
    "build": "vite build",
    "build:ssr": "vite build --ssr src/entry-server.tsx --outDir dist-ssr",
    "build:prerender": "npm run build && npm run build:ssr && node scripts/prerender.mjs",
    "prerender": "node scripts/prerender.mjs",
    "preview": "vite preview",
    "a11y:preview": "vite preview --host 127.0.0.1 --port 4173",
    "route:smoke": "node ./scripts/check-route-health.mjs http://127.0.0.1:4173 / /kontakt /mitglied-werden /spenden /forum /spiel /login /barrierefreiheit",
    "lint": "tsc --noEmit && eslint . --ext .ts,.tsx,.js,.jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest",
    "tokens:build": "node ./scripts/generate-design-tokens.mjs",
    "lh:ci": "node ./scripts/run-lighthouse.mjs",
    "a11y:test": "node ./scripts/run-pa11y-audit.mjs",
    "a11y:start": "vite --port 5173"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^5.2.0",
    "@stripe/stripe-js": "^8.1.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.546.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.9.4",
    "recharts": "^3.3.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@types/recharts": "^1.8.29",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.37.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^27.0.0",
    "lighthouse": "^13.0.0",
    "pa11y": "^6.2.3",
    "pa11y-ci": "^3.1.0",
    "playwright-core": "^1.56.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.0"
  }
}
