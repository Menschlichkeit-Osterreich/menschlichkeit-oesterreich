# FastAPI environment template
# Canonical variable names:
#   - ENVIRONMENT
#   - JWT_SECRET_KEY
#   - MOE_API_TOKEN
#   - N8N_WEBHOOK_SECRET
#
# Deprecated fallbacks still supported temporarily:
#   - APP_ENV
#   - JWT_SECRET
#   - INTERNAL_API_TOKEN
#   - INTERNAL_API_SECRET

# Core runtime
ENVIRONMENT=development
DATABASE_URL=postgresql://moe:dev_only@localhost:5432/menschlichkeit
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_KEY
JWT_ALGORITHM=HS256
ADMIN_EMAILS=admin@menschlichkeit-oesterreich.at
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
PUBLIC_APP_URL=http://localhost:5173

# CRM integration
CIVICRM_BASE_URL=https://crm.menschlichkeit-oesterreich.at
CIVICRM_SITE_KEY=CHANGE_ME_CIVICRM_SITE_KEY
CIVICRM_API_KEY=CHANGE_ME_CIVICRM_API_KEY

# Mail transport (Microsoft 365 Business / Exchange Online)
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=office@menschlichkeit-oesterreich.at
MAIL_PASSWORD=CHANGE_ME_MAIL_PASSWORD
MAIL_FROM_ADDRESS=office@menschlichkeit-oesterreich.at
MAIL_FROM_NAME="Verein Menschlichkeit Oesterreich"
MAIL_REPLY_TO_ADDRESS=office@menschlichkeit-oesterreich.at

# Named mailboxes
EMAIL_KONTAKT=office@menschlichkeit-oesterreich.at
EMAIL_OFFICE=office@menschlichkeit-oesterreich.at
EMAIL_INFO=info@menschlichkeit-oesterreich.at
EMAIL_ADMIN=admin@menschlichkeit-oesterreich.at
EMAIL_NOREPLY=noreply@menschlichkeit-oesterreich.at
EMAIL_LOGGING=logging@menschlichkeit-oesterreich.at
EMAIL_CIVIMAIL=civimail@menschlichkeit-oesterreich.at
EMAIL_BOUNCE=bounce@menschlichkeit-oesterreich.at
EMAIL_SUPPORT=support@menschlichkeit-oesterreich.at
EMAIL_FINANZEN=finanzen@menschlichkeit-oesterreich.at
EMAIL_VORSTAND=vorstand@menschlichkeit-oesterreich.at
EMAIL_DATENSCHUTZ=datenschutz@menschlichkeit-oesterreich.at

# Microsoft 365 / Entra / Graph (optional, fuer OAuth statt SMTP-Login)
MICROSOFT_TENANT_ID=CHANGE_ME_MICROSOFT_TENANT_ID
MICROSOFT_CLIENT_ID=CHANGE_ME_MICROSOFT_CLIENT_ID
MICROSOFT_CLIENT_SECRET=CHANGE_ME_MICROSOFT_CLIENT_SECRET
MICROSOFT_GRAPH_SENDER=office@menschlichkeit-oesterreich.at

# Internal integrations
MOE_API_TOKEN=CHANGE_ME_MOE_API_TOKEN
N8N_WEBHOOK_SECRET=CHANGE_ME_N8N_WEBHOOK_SECRET
N8N_WEBHOOK_URL=http://localhost:5678
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook/

# ERPNext / Frappe
FRAPPE_BASE_URL=https://erp.menschlichkeit-oesterreich.at
FRAPPE_API_KEY=CHANGE_ME_FRAPPE_API_KEY
FRAPPE_API_SECRET=CHANGE_ME_FRAPPE_API_SECRET
ERP_COMPANY=Menschlichkeit Oesterreich
ERP_TIMEOUT_SECONDS=12
ERP_MAX_RETRIES=2
ERP_SALES_INVOICE_SERIES=ACC-SINV-.YYYY.-
ERP_PURCHASE_INVOICE_SERIES=ACC-PINV-.YYYY.-
ERP_JOURNAL_ENTRY_SERIES=ACC-JV-.YYYY.-
ERP_COST_CENTER_DEFAULT=Hauptverein - MOE
ERP_CUSTOMER_GROUP=All Customer Groups
ERP_SUPPLIER_GROUP=All Supplier Groups
ERP_TERRITORY=All Territories
ERP_BANK_ACCOUNT=1100 - Bank - MOE
ERP_STRIPE_CLEARING_ACCOUNT=1360 - Stripe Clearing - MOE
ERP_SEPA_CLEARING_ACCOUNT=1370 - SEPA Clearing - MOE
ERP_CASH_ACCOUNT=1000 - Kassa - MOE
ERP_MEMBERSHIP_ITEM_CODE=MEMBERSHIP-FEE
ERP_DONATION_ITEM_CODE=DONATION
ERP_EVENT_ITEM_CODE=EVENT-INCOME
ERP_MEMBERSHIP_INCOME_ACCOUNT=4000 - Mitgliedsbeitraege - MOE
ERP_DONATION_INCOME_ACCOUNT=4100 - Spenden - MOE
ERP_EVENT_INCOME_ACCOUNT=4200 - Veranstaltungserloese - MOE
ERP_EXPENSE_ACCOUNT_DEFAULT=7300 - Sonstige Aufwendungen - MOE

# Azure AI / Foundry / Observability (optional)
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=https://YOUR_PROJECT.services.ai.azure.com/api/projects/YOUR_PROJECT
AZURE_AI_FOUNDRY_MODEL_DEPLOYMENT=gpt-4o-mini
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=CHANGE_ME;IngestionEndpoint=https://westeurope-5.in.applicationinsights.azure.com/

# Deprecated compatibility keys (optional during migration)
# APP_ENV=development
# JWT_SECRET=generate-at-least-32-char-secret-here
# N8N_API_KEY=CHANGE_ME_N8N_API_KEY
# INTERNAL_API_TOKEN=CHANGE_ME_INTERNAL_API_TOKEN
# INTERNAL_API_SECRET=CHANGE_ME_INTERNAL_API_SECRET

# Payments
STRIPE_SECRET_KEY=CHANGE_ME_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=CHANGE_ME_STRIPE_WEBHOOK_SECRET

# SEPA creditor data
SEPA_CREDITOR_NAME=Menschlichkeit Oesterreich
SEPA_CREDITOR_ID=AT00ZZZ00000000000
SEPA_CREDITOR_IBAN=AT000000000000000000
SEPA_CREDITOR_BIC=SPUEAT21XXX
FINANCE_ISSUER_BANK=CHANGE_ME_BANK_NAME

# Optional storage / PDF / social media integrations
# STORAGE_BASE_URL=https://api.menschlichkeit-oesterreich.at/storage
# PDF_STORAGE_PATH=/tmp/pdfs
# SOCIAL_DRY_RUN=true
# INSTAGRAM_ACCESS_TOKEN=CHANGE_ME_INSTAGRAM_ACCESS_TOKEN
# INSTAGRAM_USER_ID=CHANGE_ME_INSTAGRAM_USER_ID
# FACEBOOK_PAGE_ACCESS_TOKEN=CHANGE_ME_FACEBOOK_PAGE_ACCESS_TOKEN
# FACEBOOK_PAGE_ID=CHANGE_ME_FACEBOOK_PAGE_ID
# X_BEARER_TOKEN=CHANGE_ME_X_BEARER_TOKEN
# X_API_KEY=CHANGE_ME_X_API_KEY
# X_API_SECRET=CHANGE_ME_X_API_SECRET
# X_ACCESS_TOKEN=CHANGE_ME_X_ACCESS_TOKEN
# X_ACCESS_SECRET=CHANGE_ME_X_ACCESS_SECRET
# LINKEDIN_ACCESS_TOKEN=CHANGE_ME_LINKEDIN_ACCESS_TOKEN
# LINKEDIN_ORG_ID=CHANGE_ME_LINKEDIN_ORG_ID
# REPLIT_DEV_DOMAIN=your-replit-dev-domain
