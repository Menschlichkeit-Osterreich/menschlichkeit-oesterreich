# Test credentials template
# Copy to .env.test.local for local-only usage. Never commit .env.test.local.

# Database connection (local)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/menschlichkeit

# Canonical API runtime flags for tests
ENVIRONMENT=test
JWT_SECRET_KEY=CHANGE_ME_TEST_JWT_SECRET_KEY
PUBLIC_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:8001/api
VITE_API_BASE_URL=http://localhost:8001

# Test login credentials
TEST_SYSADMIN_EMAIL=test-sysadmin@menschlichkeit-oesterreich.at
TEST_SYSADMIN_PASSWORD=TestSysAdmin2025!

